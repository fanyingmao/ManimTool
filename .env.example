# ===== LLM 提供方配置 =====
# 仅需要使用的提供方启用即可
LLM_PROVIDER=openai          # openai | anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=             # 可选：自定义网关地址

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ===== TTS 配置 =====
TTS_PROVIDER=edge            # edge (Edge-TTS)
TTS_VOICE=zh-CN-XiaoxiaoNeural   # 例如：zh-CN-XiaoxiaoNeural / zh-CN-YunxiNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ===== 渲染配置 =====
MERMAID_CLI_BIN=mmdc         # mermaid-cli 可执行文件路径（npm i -g @mermaid-js/mermaid-cli）
MERMAID_THEME=default        # default | dark | forest | neutral
RENDER_BACKGROUND=transparent

# ===== FFmpeg =====
FFMPEG_BIN=ffmpeg

# ===== 输出 =====
OUTPUT_DIR=./output
CACHE_DIR=./.cache
LOG_LEVEL=INFO
